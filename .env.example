# =============================================================================
# Sinal — variáveis de ambiente
#
# Copie este arquivo para `.env` e preencha os valores. NUNCA commite o `.env`
# (ele é gitignored). Os valores abaixo são placeholders, não segredos reais.
#
# O app lê `process.env` diretamente. Ao rodar com Bun, o `.env` da raiz é
# carregado automaticamente. Você também pode carregá-lo no shell antes de
# iniciar qualquer processo:
#
#   set -a && source .env && set +a
#
# =============================================================================

# ── Obrigatórias ─────────────────────────────────────────────────────────────

# Connection string do Postgres do seu banco Supabase (use a URL do transaction
# pooler). Lida pelo Drizzle e pelo pool pg. DATABASE_URL é aceito como fallback
# caso esta não esteja definida.
SUPABASE_DB_URL=postgresql://user:password@host:6543/postgres

# URL do projeto Supabase e a chave service-role. APENAS NO SERVIDOR — a chave
# service-role ignora o Row Level Security, então nunca a envie para o navegador.
# Usadas pelo servidor de API e pelo script de bootstrap de auth (admin API do
# Supabase Auth).
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# Segredo usado para assinar o cookie de sessão. Use uma string aleatória longa,
# por exemplo:
#   openssl rand -hex 32
SESSION_SECRET=change-me-to-a-long-random-string

# Dá escopo a toda leitura da tabela read-only `whatsapp_messages`: apenas linhas
# cuja coluna `whatsapp_owner` bate com este valor são lidas. Tipicamente um
# número de telefone.
WHATSAPP_OWNER=5511999999999

# Chave de API da OpenAI — alimenta os jobs de IA (classificação, clustering de
# tópicos, detecção de menções, análise de contato).
OPENAI_API_KEY=sk-...

# Porta em que o processo escuta. TANTO o servidor de API quanto o dev server web
# leem PORT e falham rápido se ela faltar. Ao rodar os dois lado a lado
# localmente, dê a cada um a sua própria porta na linha de comando (veja
# docs/INSTALACAO.md), não aqui.
PORT=8080

# Caminho base em que o app web é servido. Use "/" para desenvolvimento local.
BASE_PATH=/

# Para onde o dev/preview server web faz proxy de "/api". Padrão
# http://localhost:8080 (a porta local do servidor de API). Sobrescreva apenas se
# o seu servidor de API rodar em outro host ou porta.
# API_PROXY_TARGET=http://localhost:8080

# ── Usuário admin (criado pelo script `bootstrap-auth`) ──────────────────────
# bootstrap-auth cria/atualiza um único login de admin. Ambos são OBRIGATÓRIOS
# (o script não tem senha padrão) — defina os seus antes de rodar.
ADMIN_EMAIL=you@example.com
ADMIN_PASSWORD=set-a-strong-password

# ── Opcional: URL de banco alternativa ───────────────────────────────────────
# Aceita no lugar de SUPABASE_DB_URL. Os testes de paridade também a usam para
# apontar para um Postgres local descartável.
# DATABASE_URL=postgresql://user:password@localhost:5432/sinal

# ── Opcional: seleção de provedor de IA ──────────────────────────────────────
# "openai" (padrão) ou "openrouter". O OpenRouter permite rodar modelos mais
# baratos (ex.: DeepSeek) para os backfills grandes de texto.
# CLASSIFY_PROVIDER=openai
# Sobrescreve o modelo usado para classificação / clustering / menções.
# CLASSIFY_MODEL=
# Necessárias apenas quando CLASSIFY_PROVIDER=openrouter:
# AI_INTEGRATIONS_OPENROUTER_API_KEY=sk-or-...
# AI_INTEGRATIONS_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ── Opcional: Google OAuth (sincronização de Contatos) ───────────────────────
# Necessário apenas se você usar a integração de Contatos do Google. O app só
# lança erro quando esse recurso é de fato invocado, então pode deixar em branco.
# GOOGLE_CLIENT_ID=...apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=...

# ── Opcional: auto-refresh do pipeline (servidor de API) ─────────────────────
# O servidor de API roda um scheduler de refresh a cada 6h. Desabilite com
# AUTO_REFRESH_DISABLED=1 (ex.: quando preferir um Scheduled Deployment dedicado).
# O intervalo é sobrescrevível via AUTO_REFRESH_INTERVAL_MS (em milissegundos).
# AUTO_REFRESH_DISABLED=1
# AUTO_REFRESH_INTERVAL_MS=21600000

# ── Opcional: nível de log ───────────────────────────────────────────────────
# Nível do logger do servidor (pino). Padrão "info".
# LOG_LEVEL=info

# ── Opcional: ajuste de jobs (sobrescreve padrões no código; ver scripts/src) ─
# SAMPLE_SIZE=        # linhas por amostra de classificação
# BATCH_SIZE=         # mensagens por lote de IA
# CONCURRENCY=        # requisições de IA em paralelo
# PAGE=               # tamanho de página para backfills paginados
# MAX_MESSAGES=       # limite total de mensagens processadas
# MENTION_SAMPLE=     # mensagens varridas em busca de menções
# SCOPE=              # restringe um job a um escopo
# TOPIC_PHRASE_CAP=   # máximo de frases por tópico

# ── Opcional: janela da métrica de tempo de resposta ─────────────────────────
# Janela de horário comercial usada pelas métricas de tempo de resposta.
# RESPONSE_TIME_START_HOUR=9
# RESPONSE_TIME_END_HOUR=18
# RESPONSE_TIME_TZ=America/Sao_Paulo

# ── Importação uazapi (rodar local) ──────────────────────────────────────────
# Base URL e token da sua instância uazapi. Usados por `import-uazapi`.
UAZAPI_BASE_URL=https://sua-instancia.uazapi.com
UAZAPI_TOKEN=seu-token-de-instancia
# Ajuste de importação (opcionais; use para pilotar barato):
# IMPORT_CHAT_LIMIT=    # nº máx. de chats a percorrer
# IMPORT_MSG_LIMIT=     # nº máx. de mensagens por chat
# IMPORT_SINCE=         # data mínima ISO, ex.: 2025-01-01

# ── URL pública do app (deploy) ──────────────────────────────────────────────
# Base URL pública onde o app é servido. Usada para montar o redirect do Google
# OAuth (tela Conectores). Ex.: https://radar.seudominio.com
PUBLIC_APP_URL=
